# ── Base ─────────────────────────────────────────────────────────────────────
FROM python:{{ python_version }}-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

# On ne copie que le pyproject.toml pour que l'image puisse générer le lock
COPY pyproject.toml ./

# On génère le lock à la volée dans l'image, puis on installe de façon figée sans les dépendances de dev
RUN uv lock && uv sync --frozen --no-dev --no-install-project

# ── Dev ──────────────────────────────────────────────────────────────────────
FROM base AS dev

COPY . .
RUN uv sync --frozen

ENTRYPOINT ["/bin/bash"]

# ── Prod ─────────────────────────────────────────────────────────────────────
FROM base AS prod

RUN useradd --create-home appuser
USER appuser

COPY . .
RUN uv sync --frozen --no-dev

ENTRYPOINT ["python", "-m", "{{ project_slug }}"]
