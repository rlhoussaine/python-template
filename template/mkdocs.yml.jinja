site_name: "{{ project_name }}"
site_description: "{{ project_description }}"
repo_url: "https://github.com/{{ github_username }}/{{ project_slug }}"

theme:
  name: material
  palette:
    - scheme: default
      primary: indigo

plugins:
  - search
  - mkdocstrings:
      handlers:
        python:
          paths: [src]

nav:
  - Home: index.md
