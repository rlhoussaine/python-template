# justfile — cross-platform task runner
# Run `just` or `just --list` to see all available commands.

# List all available recipes
default:
    @just --list

# Install the project and all its dependencies
install:
    uv sync --all-groups
{% if use_pre_commit %}
    uv run pre-commit install --install-hooks
{% endif %}

# Update dependencies to their latest compatible versions
update:
    uv lock --upgrade
    uv sync --all-groups
{% if use_pre_commit %}
    uv run pre-commit autoupdate
{% endif %}

# Run tests (native argument passing: `just test -k pattern`)
test *args:
    uv run pytest --cov {{ '{{' }}args{{ '}}' }}

# Unit tests only
test-ut *args:
    uv run pytest tests/ut/ {{ '{{' }}args{{ '}}' }}

# Integration tests only
test-it *args:
    uv run pytest tests/it/ {{ '{{' }}args{{ '}}' }}

# Format + lint + type-check (auto-fix)
lint:
    uv run ruff format src/ tests/
    uv run ruff check --fix src/ tests/
    uv run ty check src/
    uv run deptry src/

# Check without modifying (used in CI)
check:
    uv run ruff format --check src/ tests/
    uv run ruff check src/ tests/
    uv run ty check src/
    uv run deptry src/

# Security audit of dependencies
audit:
    uv run pip-audit

{% if use_pre_commit %}
# Run all pre-commit hooks on the entire project
pre-commit:
    uv run pre-commit run --all-files
{% endif %}

{% if use_docs %}
# Serve documentation locally (live-reload)
docs-serve:
    uv run mkdocs serve

# Build documentation in strict mode
docs-build:
    uv run mkdocs build --strict
{% endif %}

{% if use_docker %}
# Build Docker images (dev + prod)
docker-build:
    docker build -t {{ project_slug }}:dev --target dev .
    docker build -t {{ project_slug }}:latest --target prod .

# Run the production container
docker-run:
    docker run --rm -it {{ project_slug }}:latest
{% endif %}

# Clean generated artifacts
clean:
    rm -rf dist/ build/ .coverage htmlcov/ .pytest_cache/ .ruff_cache/ site/
    find . -type d -name __pycache__ -exec rm -rf {} +
