[build-system]
{% if package_manager == "uv" -%}
requires = ["hatchling"]
build-backend = "hatchling.build"
{% else -%}
requires = ["poetry-core>=1.0.0"]
build-backend = "poetry.core.masonry.api"
{% endif %}

{% if package_manager == "uv" -%}
[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
license = "{{ license }}"
requires-python = ">={{ python_version }}"
authors = [
    { name = "{{ author }}", email = "{{ email }}" },
]
dependencies = []

[project.optional-dependencies]
dev = [
    "ruff>=0.8",
    "mypy>=1.13",
{% if use_pre_commit -%}
    "pre-commit>=4.0",
{% endif -%}
]
test = [
    "pytest>=8.0",
    "pytest-cov>=6.0",
]
{% if use_docs -%}
docs = [
    "mkdocs>=1.6",
    "mkdocs-material>=9.5",
    "mkdocstrings[python]>=0.27",
]
{% endif -%}
{% if use_cli -%}
cli = ["click>=8.1"]
{% endif %}

{% if use_cli -%}
[project.scripts]
{{ project_slug }} = "{{ project_slug }}.cli:main"
{% endif -%}

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_slug }}"]

{% else -%}
[tool.poetry]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
authors = ["{{ author }} <{{ email }}>"]
readme = "README.md"
license = "{{ license }}"
packages = [{ include = "{{ project_slug }}", from = "src" }]

[tool.poetry.dependencies]
python = "^{{ python_version }}"

[tool.poetry.group.dev.dependencies]
ruff = ">=0.8"
mypy = ">=1.13"
{% if use_pre_commit -%}
pre-commit = ">=4.0"
{% endif -%}

[tool.poetry.group.test.dependencies]
pytest = ">=8.0"
pytest-cov = ">=6.0"

{% if use_docs -%}
[tool.poetry.group.docs.dependencies]
mkdocs = ">=1.6"
mkdocs-material = ">=9.5"
mkdocstrings = {extras = ["python"], version = ">=0.27"}
{% endif -%}

{% if use_cli -%}
[tool.poetry.scripts]
{{ project_slug }} = "{{ project_slug }}.cli:main"
{% endif -%}
{% endif %}

# ─── Ruff ────────────────────────────────────────────────────────────────────
[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 100
src = ["src", "tests"]

[tool.ruff.lint]
select = [
    "E",    # pycodestyle errors
    "W",    # pycodestyle warnings
    "F",    # pyflakes
    "I",    # isort
    "N",    # pep8-naming
    "UP",   # pyupgrade
    "B",    # flake8-bugbear
    "SIM",  # flake8-simplify
    "RUF",  # ruff-specific
]
# Pour activer les vérifications de sécurité (remplace Bandit) :
# Ajouter "S" à la liste select ci-dessus

[tool.ruff.lint.isort]
known-first-party = ["{{ project_slug }}"]

# ─── Mypy ────────────────────────────────────────────────────────────────────
[tool.mypy]
python_version = "{{ python_version }}"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false

# ─── Pytest ──────────────────────────────────────────────────────────────────
[tool.pytest.ini_options]
testpaths = ["tests"]
markers = [
    "unit: unit tests",
    "integration: integration tests",
]
addopts = "--strict-markers -v"

[tool.coverage.run]
source = ["src/{{ project_slug }}"]
omit = ["tests/*"]

[tool.coverage.report]
show_missing = true
fail_under = 0
