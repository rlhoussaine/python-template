name: Release

on:
  push:
    branches: [main]

permissions:
  contents: write
  pull-requests: write

jobs:
  release-please:
    runs-on: ubuntu-latest
    steps:
      - uses: googleapis/release-please-action@v4 # TODO: pin to SHA — verify at https://github.com/googleapis/release-please-action/releases
        with:
          release-type: python
          token: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}
