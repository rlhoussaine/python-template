name: Publish to PyPI

on:
  release:
    types: [published]

concurrency:
  group: publish-${{ "{{" }} github.ref {{ "}}" }}
  cancel-in-progress: false

permissions:
  contents: read

jobs:
  build:
    name: Build distributions
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4

      - name: Install uv
        uses: astral-sh/setup-uv@v5 # TODO: pin to SHA — vérifier sur https://github.com/astral-sh/setup-uv/releases
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install {{ python_version }}

      - name: Build distributions
        run: uv build

      - name: Upload distributions
        uses: actions/upload-artifact@v4 # TODO: pin to SHA — vérifier sur https://github.com/actions/upload-artifact/releases
        with:
          name: dist
          path: dist/

  publish:
    name: Publish to PyPI (Trusted Publishing)
    needs: build
    runs-on: ubuntu-latest
    timeout-minutes: 10
    environment:
      name: pypi
      url: https://pypi.org/p/{{ project_slug }}
    permissions:
      id-token: write
      attestations: write
      contents: read
    steps:
      - name: Download distributions
        uses: actions/download-artifact@v4 # TODO: pin to SHA — vérifier sur https://github.com/actions/download-artifact/releases
        with:
          name: dist
          path: dist/

      - name: Generate SLSA provenance attestations
        uses: actions/attest-build-provenance@v2 # TODO: pin to SHA — vérifier sur https://github.com/actions/attest-build-provenance/releases
        with:
          subject-path: 'dist/*'

      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1 # TODO: pin to SHA — vérifier sur https://github.com/pypa/gh-action-pypi-publish/releases
